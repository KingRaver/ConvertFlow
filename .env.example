NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/convertflow
# Local-only escape hatch. Leave false in any durable deployment.
ALLOW_MEMORY_STORAGE=false
EMBEDDED_CONVERSION_WORKER=true
STORAGE_DRIVER=local
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Required whenever STORAGE_DRIVER=local. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOCAL_FILESTORE_SIGNING_SECRET=replace-with-a-random-64-char-secret
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
LOG_LEVEL=info
MONITORING_TOKEN=
SENTRY_DSN=
